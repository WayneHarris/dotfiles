# Sample gitconfig
#
# You probably want to change the [user] section here since you are not me.
[user]
    name = AUTHORNAME
    email = AUTHOREMAIL
[credential]
    helper = GIT_CREDENTIAL_HELPER
[color]
    diff   = auto
    status = auto
    branch = auto
[color "diff-highlight"]
    oldNormal    = red
    oldHighlight = red bold 52
    newNormal    = green
    newHighlight = green bold 22
[core]
    excludesfile      = ~/.gitignore
    editor            = vim
    compression       = -1
    autocrlf          = input
    whitespace        = trailing-space,space-before-tab
    precomposeunicode = true
    pager             = diff-so-fancy | less --tabs=4 -RFX
[apply]
    whitespace = nowarn
[help]
    autocorrect = 10
[merge]
    tool = diffmerge
[mergetool "diffmerge"]
    cmd           = diffmerge --merge --result=$MERGED $LOCAL $BASE $REMOTE
    trustExitCode = true
    keepBackup    = false
[diff]
    tool       = diffmerge
    algorithm  = histogram
    colorMoved = default
[difftool "diffmerge"]
    cmd = diffmerge $LOCAL $REMOTE
[difftool]
    prompt = false
[grep]
    extendRegexp = true
    lineNumber   = true
[pager]
    diff = diff-so-fancy | less --tabs=4 -RFX
    log  = diff-so-fancy | less --tabs=4 -RFX
    show = diff-so-fancy | less --tabs=4 -RFX
[pull]
    ff = only
[rerere]
    enabled = true
[rebase]
    autoStash = true
[branch]
    sort = -committerdate
